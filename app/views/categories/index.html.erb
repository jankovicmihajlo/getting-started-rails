<h1><%= t(".title") %></h1>

<h2><%= t(".new_category") %></h2>
<%= render "form", category: @category %>

<ul>
  <% @categories.each do |category| %>
    <li>
      <%= category.name %>
      <%= link_to t(".edit"), edit_category_path(category) %>
      <%= button_to t(".delete"), category_path(category), method: :delete, data: { turbo_confirm: t(".delete_confirm") } %>
    </li>
  <% end %>
</ul>

<%= link_to t(".back_to_products"), products_path %>